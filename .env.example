# Copy this file to .env and fill in your values for local development.
# .env is gitignored — never commit it.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
GEMINI_API_KEY=your-gemini-api-key-here
SIMPLYPRINT_API_KEY=your-simplyprint-api-key-here

# Shared secret required in the X-Orbot-Key header for all protected backend routes.
# Generate a long random value and set the same one in the frontend's config.
ORBOT_API_KEY=

# Comma-separated list of origins allowed to call this API via CORS (e.g. the deployed
# dashboard's URL(s)). Leave empty to allow none (safer default than "*").
ALLOWED_ORIGINS=

# Railway cloud deployment — paste the raw JSON content of each file as a single line.
# These are written to disk at startup if the files don't already exist.
GOOGLE_TOKEN_JSON=
GOOGLE_CREDENTIALS_JSON=

# Gmail push notifications (optional — Scout falls back to polling when unset).
# Topic like projects/<project>/topics/<topic>; token must match the ?token= query
# param configured on the /gmail/notifications push subscription.
GMAIL_PUBSUB_TOPIC=
GMAIL_PUSH_TOKEN=

# Telegram control bot (cloud_function/main.py — set these on the Google Cloud
# Function, not Railway). ORBOT_API_KEY there must match the value above so the
# bot can call the foreman edge function / backend.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# Discord notifications (error/warning alerts + daily summary).
# NOT read by main.py — this is a Supabase Edge Function secret. Set it via
# `supabase secrets set DISCORD_WEBHOOK_URL=...` or the Supabase Dashboard
# (Edge Functions -> Secrets), not here. Listed for documentation only.
DISCORD_WEBHOOK_URL=
