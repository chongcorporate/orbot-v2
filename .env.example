# Copy this file to .env and fill in your values for local development.
# .env is gitignored — never commit it.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
GEMINI_API_KEY=your-gemini-api-key-here
SIMPLYPRINT_API_KEY=your-simplyprint-api-key-here

# Railway cloud deployment — paste the raw JSON content of each file as a single line.
# These are written to disk at startup if the files don't already exist.
GOOGLE_TOKEN_JSON=
GOOGLE_CREDENTIALS_JSON=
