# ── Secrets (NEVER commit these) ─────────────────────────────────────────────
.env
token.json
credentials.json

# ── Claude Code local config (settings.local.json embeds real API keys) ─────
.claude/settings.local.json
.claude/worktrees/
.agents/

# ── Supabase local config (leaks a Postgres pooler connection string) ───────
supabase/.temp/

# ── Local throwaway scripts (may contain DB creds — keep out of git) ─────────
scratch/

# ── Runtime / generated cache files ──────────────────────────────────────────
scout.lock
sp_files.json
sp_folders_cache.json
db_files.json
match_preview.json

# ── Local print files & uploads (too large, machine-specific) ────────────────
Blocked Off Print Files/
Uploads/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ── Node ─────────────────────────────────────────────────────────────────────
node_modules/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vercel

# Vercel project link (machine-specific)
.vercel/
